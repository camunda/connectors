        <groupId>io.camunda.connector</groupId>
        <artifactId>connector-agentic-ai-agent</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.camunda.connector</groupId>
        <artifactId>connector-agentic-ai-mcp</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.camunda.connector</groupId>
        <artifactId>connector-agentic-ai-a2a</artifactId>
        <version>${project.version}</version>
