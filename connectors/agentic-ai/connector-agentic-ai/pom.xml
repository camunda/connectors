    <!--
      OkHttp 5 split into multi-platform modules: the `okhttp` artifact's pom is now an empty shell
      (classes ship in `okhttp-jvm`), see the comment in parent/pom.xml. anthropic-java-client-okhttp
      only depends on the empty `okhttp` shell, so AnthropicOkHttpClient.builder().build() throws
      NoClassDefFoundError at runtime unless we add `okhttp-jvm` explicitly (same pattern as
      connectors/slack and connectors/microsoft/common).
    -->
    <dependency>
      <groupId>com.squareup.okhttp3</groupId>
      <artifactId>okhttp-jvm</artifactId>
      <version>${version.okhttp}</version>
    </dependency>

