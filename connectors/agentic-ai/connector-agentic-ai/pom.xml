          <execution>
            <id>generate-subprocess-v2-template-hybrid</id>
            <phase>process-classes</phase>
            <goals>
              <goal>execute</goal>
            </goals>
            <configuration>
              <scripts>
                <script>file:///${project.basedir}/bin/transform-ai-agent-subprocess-v2-template.groovy</script>
              </scripts>
              <properties>
                <property>
                  <name>sourceFile</name>
                  <value>
                    ${project.basedir}/element-templates/hybrid/agenticai-ai-agent-task.v2-hybrid.json
