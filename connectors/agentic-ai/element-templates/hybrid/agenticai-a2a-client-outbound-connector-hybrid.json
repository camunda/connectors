    "condition" : {
      "property" : "data.operation.type",
      "equals" : "sendMessage",
      "type" : "simple"
    },
    "type" : "Text"
  }, {
    "id" : "data.operation.documents",
    "label" : "Documents",
    "description" : "Documents to be included in the message.",
    "optional" : true,
    "feel" : "required",
    "group" : "operation",
    "binding" : {
      "name" : "data.operation.documents",
      "type" : "zeebe:input"
