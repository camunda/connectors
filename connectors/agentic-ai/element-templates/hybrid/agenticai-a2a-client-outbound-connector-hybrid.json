{
  "$schema" : "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name" : "Hybrid A2A Client (experimental)",
  "id" : "io.camunda.connectors.agenticai.a2a.client.v0-hybrid",
