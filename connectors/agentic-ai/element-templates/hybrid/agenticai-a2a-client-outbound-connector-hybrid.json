    "group" : "connection",
    "binding" : {
      "name" : "data.connection.url",
      "type" : "zeebe:input"
    },
    "type" : "String"
  }, {
    "id" : "data.connection.agentCardLocation",
    "label" : "Agent card location",
    "description" : "Optional path to the agent card endpoint relative to the base server URL, defaults to \".well-known/agent-card.json\"",
    "optional" : true,
    "feel" : "optional",
    "group" : "connection",
    "binding" : {
      "name" : "data.connection.agentCardLocation",
      "type" : "zeebe:input"
