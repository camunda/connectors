    "optional" : false,
    "value" : "PT1M",
    "feel" : "optional",
    "group" : "operation",
    "binding" : {
      "name" : "data.operation.timeout",
      "type" : "zeebe:input"
    },
    "condition" : {
      "property" : "data.operation.type",
      "equals" : "sendMessage",
      "type" : "simple"
    },
    "type" : "String"
  }, {
    "id" : "version",
    "label" : "Version",
    "description" : "Version of the element template",
    "value" : "0",
    "group" : "connector",
    "binding" : {
      "key" : "elementTemplateVersion",
      "type" : "zeebe:taskHeader"
    },
    "type" : "Hidden"
  }, {
    "id" : "id",
    "label" : "ID",
    "description" : "ID of the element template",
    "value" : "io.camunda.connectors.agenticai.a2a.client.v0",
    "group" : "connector",
    "binding" : {
      "key" : "elementTemplateId",
      "type" : "zeebe:taskHeader"
    },
    "type" : "Hidden"
  }, {
    "id" : "resultVariable",
    "label" : "Result variable",
    "description" : "Name of variable to store the response in",
